#!/usr/bin/env bash
# win-ctl - send control commands to a win REPL buffer

source "$HOME/.ad/lib/ad.sh"

requireAd

if [ $# -lt 1 ]; then
  adError "usage: win-ctl [buffer] <command...>"
fi

TARGET_NAME="+win"
if [[ "$1" == +* ]]; then
  TARGET_NAME="$1"
  shift
fi

if [ $# -lt 1 ]; then
  adError "missing command. usage: win-ctl [buffer] <command...>"
fi

# 查找目标 buffer 的 ID
BUFFER_INDEX="$(adIndex)"
WIN_BUFFER_ID=""
while IFS=$'\t' read -r buf_id buf_name; do
  if [[ "$buf_name" == *"$TARGET_NAME"* ]]; then
    WIN_BUFFER_ID="$buf_id"
    break
  fi
done <<< "$BUFFER_INDEX"

if [ -z "$WIN_BUFFER_ID" ]; then
  adError "$TARGET_NAME buffer not found. Run win first"
fi

SEND_PREFIX="${SEND_PREFIX:-;; }"
CMD=":win $*"
printf "%s%s\n\n" "$SEND_PREFIX" "$CMD" | bufWrite "$WIN_BUFFER_ID" body

adCtl "echo Sent control to $TARGET_NAME"
